# Piakarn Parking Space — Frontend Config
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ค่าเหล่านี้ปลอดภัยที่จะอยู่ฝั่ง frontend
# เพราะเป็น "publishable"/public key เท่านั้น — Secret Key ห้ามใส่ที่นี่)

# URL ของ Apps Script Web App หลัง deploy (Deploy > New deployment > Web App)
APPS_SCRIPT_API_URL=

# Stripe Publishable Key (ขึ้นต้นด้วย pk_test_ หรือ pk_live_)
STRIPE_PUBLISHABLE_KEY=

# Google Maps JavaScript API Key (จำกัดสิทธิ์เฉพาะ Maps JS + Distance Matrix)
GOOGLE_MAPS_API_KEY=

# ------------------------------------------------------------------
# ค่าที่เป็น "ความลับจริง" (Stripe Secret Key, Google Sheet ID) ห้ามใส่ในไฟล์นี้
# ให้ไปตั้งค่าใน Google Apps Script > Project Settings > Script Properties แทน:
#   SHEET_ID          = <Google Sheet ID>
#   STRIPE_SECRET_KEY = sk_test_xxxxxxxx
# ------------------------------------------------------------------
